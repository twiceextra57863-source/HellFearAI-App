<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://android.com"
    xmlns:app="http://android.com"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#121212"> <!-- Dark Theme -->

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1F1F1F"
            app:title="HellFearAI"
            app:titleTextColor="#FF0000" />

        <!-- AI Selection Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:background="#1F1F1F">
            <Button android:id="@+id/btn_chatgpt" android:layout_width="0dp" android:layout_weight="1" android:text="GPT" android:backgroundTint="#444" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_gemini" android:layout_width="0dp" android:layout_weight="1" android:text="Gemini" android:backgroundTint="#444" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_deepseek" android:layout_width="0dp" android:layout_weight="1" android:text="DeepSeek" android:backgroundTint="#444" android:layout_margin="2dp"/>
        </LinearLayout>

        <WebView
            android:id="@+id/ai_webview"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <EditText
            android:id="@+id/code_input"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:hint="Paste AI Code Here..."
            android:textColorHint="#888"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:gravity="top"
            android:padding="10dp"
            android:background="#000" />

        <Button
            android:id="@+id/btn_compile"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="COMPILE TO JAR"
            android:textStyle="bold"
            android:backgroundTint="#FF0000" />
    </LinearLayout>

    <!-- Side Navigation Menu -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/side_menu"
        android:background="#1F1F1F" />

</androidx.drawerlayout.widget.DrawerLayout>
